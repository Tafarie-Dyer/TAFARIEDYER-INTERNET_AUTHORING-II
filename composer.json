{
  "name": "ucc/ucc-it-web-app",
  "type": "project",
  "description": "UCC IT Web App progressive web app built with Laravel.",
  "keywords": ["laravel", "pwa", "ucc", "it"],
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0",
    "erag/laravel-pwa": "^2.1"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi",
      "@php artisan migrate --seed --ansi"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
